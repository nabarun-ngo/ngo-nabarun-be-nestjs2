{
  "name": "@ce/api",
  "version": "1.0.0",
  "description": "Consumer NestJS application built on top of nestjs-shared — migration target for be-nestjs-stage",
  "private": true,
  "scripts": {
    "generate:db": "npx prisma generate",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "start:redis": "powershell -ExecutionPolicy Bypass -File \"./scripts/Start-Redis.ps1\"",
    "prebuild": "npm run clean && npm run generate:db",
    "clean": "rimraf dist && rimraf .turbo && rimraf src/shared/persistence/prisma",
    "build": "nest build",
    "build:watch": "nest build --watch",
    "prestart:debug": "npm run start:redis",
    "prestart:watch": "npm run start:redis",
    "start": "node dist/main",
    "start:watch": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "etl:finance:preflight": "ts-node scripts/migration/finance/preflight.ts",
    "etl:finance": "ts-node scripts/migration/finance/run-all.ts"
  },
  "dependencies": {
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/gmail": "^15.0.0",
    "@keyv/redis": "^3.0.1",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@onesignal/node-onesignal": "^5.5.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.8.0",
    "auth0": "^5.13.0",
    "aws-cron-parser": "^1.1.12",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.5",
    "bullmq": "^5.79.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cron-parser": "^5.4.0",
    "cronstrue": "^3.14.0",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "expr-eval": "^2.0.2",
    "express": "^4.18.0",
    "file-type": "^21.3.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.5.0",
    "handlebars": "^4.7.0",
    "handlebars-helpers": "^0.10.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3",
    "@ce/nestjs-shared-core": "*",
    "@ce/nestjs-shared-persistence": "*",
    "@ce/nestjs-shared-auth": "*",
    "@ce/nestjs-shared-observability": "*",
    "@ce/nestjs-shared-queue": "*",
    "@ce/nestjs-shared-json-store": "*",
    "@ce/nestjs-shared-token-vault": "*",
    "@ce/nestjs-shared-dms": "*",
    "@ce/nestjs-shared-document-generator": "*",
    "@ce/nestjs-shared-comment": "*",
    "@ce/nestjs-shared-custom-forms": "*",
    "@ce/nestjs-shared-cron": "*",
    "@ce/nestjs-shared-correspondence": "*",
    "@ce/nestjs-shared-workflow": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.0",
    "@types/compression": "^1.7.0",
    "@types/express": "^4.17.0",
    "@types/handlebars-helpers": "^0.5.6",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.2",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "overrides": {
    "cache-manager": "^5.7.6"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/src/**/*.spec.ts",
      "<rootDir>/test/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.json",
          "diagnostics": {
            "warnOnly": true
          }
        }
      ]
    },
    "testEnvironment": "node",
    "setupFiles": [
      "reflect-metadata"
    ]
  }
}