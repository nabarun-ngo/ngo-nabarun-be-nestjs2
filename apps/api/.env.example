# CE API — local development environment template
# Copy to `.env` and replace placeholder values with real credentials.
#   cp .env.example .env
#
# Required vars are loaded via ConfigService.getOrThrow() in app.module.ts.
# Optional vars have defaults in code or are only used when explicitly set.

# ── Runtime ────────────────────────────────────────────────────────────────────
# NODE_ENV: development | staging | production (controls Swagger, Slack alerts, prod email mode)
NODE_ENV=development
# ENVIRONMENT: overrides NODE_ENV for Swagger/CORS labeling if set
ENVIRONMENT=development
# PORT: HTTP listen port (default 3000)
PORT=3000
# LOG_LEVEL: log | verbose | debug | warn | error | fatal
LOG_LEVEL=log

# ── Application ──────────────────────────────────────────────────────────────
# APP_NAME: used in Swagger, email from-name, and correspondence branding
APP_NAME=CE API (Local)
# APP_SECRET: encryption key for Token Vault + Custom Fields (min 32 chars)
APP_SECRET=local-dev-app-secret-change-me-32chars-min

# ── URLs ─────────────────────────────────────────────────────────────────────
# Used in email templates, OAuth redirects, and deep links (optional but common)
APP_BE_URL=http://localhost:3000
APP_FE_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (include Nabarun public site domains in prod/stage)
CORS_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173,https://ngonabarun.web.app,https://ngonabarun-stage.web.app
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# ── Databases ────────────────────────────────────────────────────────────────
# DATABASE_URL: PostgreSQL connection string (required — also used by prisma.config.ts)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ce_api
# SOURCE_DATABASE_URL: legacy be-nestjs-stage DB (finance ETL only)
SOURCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ce_stage
# ETL_DRY_RUN: set to true to validate ETL without writing to target
# ETL_DRY_RUN=true
# REDIS_URL: Redis for cache, BullMQ queues, and correspondence dispatch
REDIS_URL=redis://localhost:6379
# MONGODB_URL: reserved in config-keys; not wired in app.module.ts today
MONGODB_URL=mongodb://localhost:27017/ce_api

# ── Auth0 (management API) ───────────────────────────────────────────────────
# Required for UserModule — provisions users via Auth0 Management API
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_MANAGEMENT_CLIENT_ID=your-auth0-management-client-id
AUTH0_MANAGEMENT_CLIENT_SECRET=your-auth0-management-client-secret

# ── JWT (Auth0 / JWKS) ───────────────────────────────────────────────────────
# Required by AuthModule — must match your Auth0 API identifier
JWT_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json
JWT_ISSUER=https://your-tenant.auth0.com/
JWT_AUDIENCE=https://api.example.com

# ── Google OAuth (Token Vault) ───────────────────────────────────────────────
# Required for Gmail/Drive/Calendar token vault integrations
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ── Fathom (meeting notes webhook) ──────────────────────────────────────────
# FATHOM_WEBHOOK_SECRET: used by FathomWebhookGuard to verify webhook signatures (whsec_... format)
FATHOM_WEBHOOK_SECRET=whsec_placeholder

# ── Google reCAPTCHA ─────────────────────────────────────────────────────────
# Required by AuthModule recaptcha config
GOOGLE_RECAPTCHA_SECURITY_KEY=your-recaptcha-secret-key
# GOOGLE_RECAPTCHA_THRESHOLD: fallback min score in unified-auth guard (default 0.5)
GOOGLE_RECAPTCHA_THRESHOLD=0.5
# RECAPTCHA_MIN_SCORE: module-level min score (default 0.65; use 0.5 for public site forms)
RECAPTCHA_MIN_SCORE=0.5

# PUBLIC_SITE_BUILD_API_KEY: API key for Next.js SSG build-time GET requests (create via auth/apikey)
# PUBLIC_SITE_BUILD_API_KEY=sk_...

# ── Firebase (DMS file storage) ──────────────────────────────────────────────
# FIREBASE_CREDENTIAL: single-line JSON service account (parsed by DmsModule)
# Values starting with "your-" disable DMS feature-gate helpers but still satisfy getOrThrow
FIREBASE_FILESTORAGE_BUCKET=ce-local-dev.appspot.com
FIREBASE_CREDENTIAL={"type":"service_account","project_id":"ce-local-dev","private_key_id":"placeholder","private_key":"-----BEGIN PRIVATE KEY-----\nPLACEHOLDER\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@nabarun-ngo-local-dev.iam.gserviceaccount.com","client_id":"123456789012345678901","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40ce-local-dev.iam.gserviceaccount.com"}

# ── Email (Correspondence) ───────────────────────────────────────────────────
# ENABLE_EMAIL_MOCKING=true routes all outbound email to MOCKED_EMAIL_ADDRESS
ENABLE_EMAIL_MOCKING=true
MOCKED_EMAIL_ADDRESS=dev@example.com
# ENABLE_PROD_MODE: force real email delivery even in non-prod (default follows NODE_ENV)
ENABLE_PROD_MODE=false
# EMAIL_SENDER: optional from-address (falls back to mocked address when mocking is on)
EMAIL_SENDER=noreply@example.com

# ── Push notifications (OneSignal) ───────────────────────────────────────────
# Required by CorrespondenceModule push adapter
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ── Observability ────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL: required; alerts only fire when NODE_ENV is production
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/PLACEHOLDER/CHANNEL/TOKEN

# ── Persistence tuning (optional) ────────────────────────────────────────────
# ENABLE_DB_AUDIT: enable Prisma audit extension (default false)
ENABLE_DB_AUDIT=false
# DB_AUDIT_MODELS: comma-separated Prisma model names to audit
DB_AUDIT_MODELS=
# REDIS_CACHE_TTL: cache TTL in milliseconds (default 600000 = 10 min)
REDIS_CACHE_TTL=600000
# FAIL_ON_AUDIT_ERROR: halt requests on audit write failure (default false)
FAIL_ON_AUDIT_ERROR=false
# MAX_FILE_SIZE_MB: DMS upload limit in MB (default 10)
MAX_FILE_SIZE_MB=10

# ── Finance ──────────────────────────────────────────────────────────────────
# PROP_DONATION_AMOUNT: default monthly donation amount (INR) when user has no custom amount
PROP_DONATION_AMOUNT=500
