// Default, built-in job registry used by CronModule when the consumer does not
// supply a custom `jobsProvider`. Managed entirely through the /cron/jobs CRUD
// endpoints — rows here are read by the default jobsProvider on every trigger
// evaluation and listing.
model CronJobDefinition {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  expression  String   @db.VarChar(50)
  handler     String   @db.VarChar(255)
  enabled     Boolean  @default(true)
  inputData   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cron_job_definition")
}
