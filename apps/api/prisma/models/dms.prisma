model DocumentReference {
  id              String            @id @default(cuid())
  fileName        String
  remotePath      String
  publicToken     String?
  contentType     String
  fileSize        Int?
  isPublic        Boolean           @default(false)
  uploadedById    String?
  /// Owning account (e.g. Google `sub`) for per-user storage providers such as Google Drive. Unused by Firebase.
  storageOwnerSub String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  mappings        DocumentMapping[]

  @@map("dms_document_reference")
}

model DocumentMapping {
  id                  String            @id @default(cuid())
  documentReferenceId String
  entityId            String
  entityType          String
  createdAt           DateTime          @default(now())
  document            DocumentReference @relation(fields: [documentReferenceId], references: [id], onDelete: Cascade)

  @@map("dms_document_mapping")
}
