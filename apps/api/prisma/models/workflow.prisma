// ─────────────────────────────────────────────────────────────────────────────
// Workflow Engine 2.0 — element-based state machine runtime
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowInstance {
  id                String    @id @db.VarChar(100)
  name              String    @db.VarChar(255)
  definitionId      String    @db.VarChar(50)
  definitionVersion Int       @default(1)
  description       String    @db.Text
  status            String    @db.VarChar(30)
  currentElementId  String?   @db.VarChar(100)
  parentInstanceId  String?   @db.VarChar(100)
  context           Json      @default("{}")
  compensationStack Json      @default("[]")
  initiatedById     String?   @db.VarChar(100)
  initiatedForId    String?   @db.VarChar(100)
  delegated         Boolean   @default(false)
  isExtUser         Boolean   @default(false)
  extUserEmail      String?   @db.VarChar(255)
  completedAt       DateTime?
  remarks           String?   @db.Text
  version           Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  parentInstance WorkflowInstance?   @relation("WorkflowParentChild", fields: [parentInstanceId], references: [id])
  childInstances WorkflowInstance[]  @relation("WorkflowParentChild")
  initiatedBy    UserProfile?        @relation("WorkflowInitiatedBy", fields: [initiatedById], references: [id])
  initiatedFor   UserProfile?        @relation("WorkflowInitiatedFor", fields: [initiatedForId], references: [id])
  eventLog       WorkflowEventLog[]
  tokens         WorkflowToken[]
  inboxItems     WorkflowTaskInbox[]
  outbox         WorkflowOutbox[]

  @@index([definitionId, status])
  @@index([status])
  @@index([initiatedForId])
  @@index([parentInstanceId])
  @@map("workflow_instances")
}

model WorkflowEventLog {
  id            String           @id @default(cuid())
  instanceId    String           @db.VarChar(100)
  instance      WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  sequence      Int              @default(1)
  eventType     String           @db.VarChar(50)
  elementId     String?          @db.VarChar(100)
  actorType     String           @db.VarChar(20)
  actorId       String?          @db.VarChar(100)
  payload       Json             @default("{}")
  correlationId String?          @db.VarChar(100)
  occurredAt    DateTime         @default(now())

  @@unique([instanceId, sequence])
  @@index([instanceId])
  @@map("workflow_event_log")
}

model WorkflowToken {
  id               String           @id @default(cuid())
  instanceId       String           @db.VarChar(100)
  instance         WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  branchId         String           @db.VarChar(100)
  parentGatewayId  String           @db.VarChar(100)
  status           String           @db.VarChar(20)
  currentElementId String           @db.VarChar(100)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([instanceId, status])
  @@map("workflow_tokens")
}

model WorkflowTaskInbox {
  id                 String           @id @default(cuid())
  instanceId         String           @db.VarChar(100)
  instance           WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  elementId          String           @db.VarChar(100)
  workflowType       String           @db.VarChar(50)
  formKey            String?          @db.VarChar(200)
  status             String           @db.VarChar(20)
  assignedToId       String?          @db.VarChar(100)
  candidateRoleNames Json             @default("[]")
  slaDeadlineAt      DateTime?
  claimedAt          DateTime?
  claimedById        String?          @db.VarChar(100)
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([instanceId, elementId])
  @@index([assignedToId, status])
  @@index([status, slaDeadlineAt])
  @@map("workflow_task_inbox")
}

model WorkflowIdempotencyKey {
  key        String   @id
  scope      String   @db.VarChar(30)
  instanceId String?  @db.VarChar(100)
  result     Json?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
  @@map("workflow_idempotency_keys")
}

model WorkflowOutbox {
  id           String           @id @default(cuid())
  instanceId   String           @db.VarChar(100)
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  eventType    String           @db.VarChar(100)
  payload      Json
  status       String           @db.VarChar(20)
  createdAt    DateTime         @default(now())
  dispatchedAt DateTime?
  lastError    String?          @db.Text

  @@index([status, createdAt])
  @@map("workflow_outbox")
}
