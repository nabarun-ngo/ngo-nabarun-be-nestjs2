// ─────────────────────────────────────────────────────────────────────────────
// Root schema file — datasource + generator only.
//
// Models are defined in prisma/models/*.prisma (multi-file schema, Prisma 7).
// All *.prisma files under prisma/ are merged at generate time.
//
// Generated client output: ../src/persistence/prisma  (gitignored)
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/persistence/prisma"
  moduleFormat = "cjs"
}
