## Module Registration

Each feature module imports `CqrsModule` and declares its own handlers and controller:

```ts
// order.module.ts
import { CqrsModule } from '@nestjs/cqrs';
import { AuthModule } from '@lib/auth';

@Module({
  imports: [
    CqrsModule,       // ← registers CommandBus, QueryBus, EventBus for this module
    AuthModule,       // ← makes UnifiedAuthGuard, RolesGuard etc. injectable
  ],
  controllers: [OrderController],
  providers: [
    // Commands
    PlaceOrderHandler,
    CancelOrderHandler,
    AddItemToOrderHandler,
    // Queries
    GetOrderByIdHandler,
    ListOrdersHandler,
    // Event handlers
    OnOrderPlacedHandler,
    // Infrastructure
    { provide: IOrderRepository, useClass: OrderPrismaRepository },
  ],
})
export class OrderModule {}
```

